<mujoco model="cartpole">
  <compiler angle="radian" coordinate="local"/>
  <option timestep="0.002" gravity="0 0 -9.81" integrator="RK4"/>

  <default>
    <geom contype="0" conaffinity="0"/>
  </default>

  <visual>
    <global offwidth="480" offheight="480"/>
  </visual>

  <asset>
    <texture name="sky_tex" type="skybox" builtin="gradient"
              rgb1="0.55 0.65 0.85" rgb2="0.92 0.93 0.97" width="256" height="256"/>

    <!-- Checker backdrop: fine periodic texture gives the encoder dense local
         gradient/edge cues to lock onto for sub-tile position precision. -->
    <texture name="grid_tex" type="2d" builtin="checker"
             rgb1="0.88 0.88 0.90" rgb2="0.72 0.74 0.80" width="800" height="800" mark="none"/>
    <material name="grid_mat" texture="grid_tex" texrepeat="5 7" texuniform="true"
              specular="0.05" shininess="0.03" reflectance="0.0"/>

    <material name="rail_mat"   rgba="0.15 0.15 0.17 1"/>
    <material name="cart_mat"   rgba="0.85 0.25 0.20 1"/>
    <material name="pole_mat"   rgba="0.20 0.40 0.85 1"/>
    <material name="tip_mat"    rgba="0.95 0.75 0.10 1"/>
    <material name="center_mat" rgba="0.15 0.70 0.35 1"/>
    <material name="bumper_mat" rgba="0.90 0.50 0.10 1"/>
  </asset>

  <worldbody>
    <light name="key" pos="0 -2.5 2.5" dir="0 0.6 -1" diffuse="1 1 1" specular="0.1 0.1 0.1"/>

    <!-- Vertical backdrop panel, face-on to the camera (camera looks along +y).
         A horizontal floor plane would be viewed edge-on from a side camera and
         collapse to an invisible line, so the position-giving texture has to live
         on a wall behind the scene instead. -->
    <geom name="backdrop" type="plane" pos="0 2.0 0.35" euler="1.57079632679 0 0"
          size="3.0 3.0 0.02" material="grid_mat"/>

    <!-- Track rail, drawn as a thin bar so the cart's baseline is always visible. -->
    <geom name="rail" type="box" pos="0 0 -0.005" size="1.35 0.02 0.005" material="rail_mat"/>

    <!-- Aperiodic landmarks: these break the checker's translational symmetry so
         absolute position is unambiguous, not just position-modulo-one-tile. -->
    <!-- TODO: Change limit based on initial controller output, to get most details in frame-->
    <geom name="center_mark" type="box" pos="0 0.01 0.001" size="0.015 0.01 0.002" material="center_mat"/>
    <geom name="bumper_left"  type="box" pos="-1.0 0 0.04" size="0.02 0.05 0.04" material="bumper_mat"/>
    <geom name="bumper_right" type="box" pos=" 1.0 0 0.04" size="0.02 0.05 0.04" material="bumper_mat"/>

    <camera name="side" pos="0 -3.2 0.55" xyaxes="1 0 0 0 0 1"/>

    <body name="cart" pos="0 0 0.05">
      <joint name="slider" type="slide" axis="1 0 0" range="-0.94 0.9" limited="true" damping="0.05"/>
      <geom name="cart_geom" type="box" size="0.1 0.06 0.05" material="cart_mat" mass="1.0"/>

      <body name="pole" pos="0 0 0.05">
        <!-- hinge angle 0 = hanging straight down (stable rest); pi = upright. -->
        <joint name="hinge" type="hinge" axis="0 1 0" damping="0.01"/>
        <geom name="pole_geom" type="capsule" fromto="0 0 0 0 0 -0.4" size="0.015" material="pole_mat" mass="0.1"/>
        <geom name="pole_tip" type="sphere" pos="0 0 -0.4" size="0.03" material="tip_mat" mass="0.01"/>
      </body>
    </body>
  </worldbody>

  <actuator>
    <motor name="cart_motor" joint="slider" ctrlrange="-10 10" gear="1"/>
  </actuator>
</mujoco>